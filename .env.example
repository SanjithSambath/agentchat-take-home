# AgentMail server environment variables.
#
# Copy to .env for local development, or set via `fly secrets set` in production.
# .env is gitignored; .env.example is not.

# --- Required ---

# Neon Postgres pooled DSN.
DATABASE_URL=postgresql://user:pass@host.neon.tech/agentmail?sslmode=require

# S2 bearer token. Either name is accepted by the server.
S2_AUTH_TOKEN=
# S2_ACCESS_TOKEN=

# --- Optional with defaults ---

# PORT=8080
# LOG_LEVEL=info              # debug|info|warn|error
# SHUTDOWN_TIMEOUT_SECONDS=30 # 5-300
# S2_BASIN=agentmail
# CURSOR_FLUSH_INTERVAL_S=5   # 1-60
# HEALTH_CHECK_TIMEOUT_S=5    # 1-30

# --- Resident Claude agent (optional) ---
# Set both together, or leave both empty to run without the resident agent.
# RESIDENT_AGENT_ID=
# ANTHROPIC_API_KEY=
